# Backend precedence (first match wins): CLAUDE_BACKEND=cli > OpenRouter > Anthropic SDK > CLI.

# --- OpenRouter (recommended for deployed demos) -----------------------------
# Multi-provider, per-key spend caps via the OpenRouter dashboard. Required to
# mix providers (e.g. Gemini for analysis + Claude for generation). With this
# set, the model env vars below MUST carry OpenRouter slugs.
# OPENROUTER_API_KEY=
# CLAUDE_ANALYSIS_MODEL=google/gemini-3.1-pro-preview
# CLAUDE_GENERATION_MODEL=anthropic/claude-sonnet-4.6
# CLAUDE_DIAGNOSIS_MODEL=google/gemini-3.1-pro-preview
# Optional attribution headers OpenRouter uses for traffic ranking.
# OPENROUTER_HTTP_REFERER=https://yourdomain.example
# OPENROUTER_X_TITLE=mp4-to-webgl

# --- Anthropic SDK (per-token billing direct) --------------------------------
# Used when OPENROUTER_API_KEY is unset and ANTHROPIC_API_KEY is set. Models
# below default to claude-opus-4-7 if unspecified.
ANTHROPIC_API_KEY=
# CLAUDE_ANALYSIS_MODEL=claude-opus-4-7
# CLAUDE_GENERATION_MODEL=claude-opus-4-7
# CLAUDE_DIAGNOSIS_MODEL=claude-sonnet-4-6

# --- Claude Code CLI (local dev only) ----------------------------------------
# Force the local CLI even if other backends are configured. Bills against
# your Claude Code subscription rather than per-token credits. Won't work in
# a remote container (macOS keychain auth doesn't travel).
# CLAUDE_BACKEND=cli

# HTTP basic auth gate. When APP_PASSWORD is set every route requires the
# (username, password) pair. Leave unset for unauthenticated local dev.
# APP_USERNAME=demo
# APP_PASSWORD=

# Gemini sandbox (scripts/sandbox-gemini.ts) — uses native video input.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-pro
